    {
        "id": "bb475c5d65aa388b",
        "type": "function",
        "z": "353ff3318499fa2d",
        "name": "Extract Dashboard Values",
        "func": "let latest = msg.payload[0];\n\n// Sensor readings\nlet temperatureMsg = {\n    payload: Number(latest.temperature ?? 0)\n};\n\nlet humidityMsg = {\n    payload: Number(latest.humidity ?? 0)\n};\n\nlet gasMsg = {\n    payload: Number(latest.gas ?? 0)\n};\n\n// Motion status\nlet motionMsg = {\n    payload: latest.motion == 1 || latest.motion === true\n        ? \"Motion Detected\"\n        : \"No Motion\"\n};\n\n// Day / night condition\nlet nightMsg = {\n    payload: latest.is_night == 1 || latest.is_night === true\n        ? \"Night\"\n        : \"Day\"\n};\n\n// Motion duration\nlet durationMsg = {\n    payload: Number(latest.motion_duration_sec ?? 0)\n};\n\n// Alert class mapping\nlet alertName = \"Unknown\";\n\nif (latest.alert_class == 0) {\n    alertName = \"Normal\";\n} else if (latest.alert_class == 1) {\n    alertName = \"Low Alert\";\n} else if (latest.alert_class == 2) {\n    alertName = \"Medium Alert\";\n} else if (latest.alert_class == 3) {\n    alertName = \"High Alert\";\n}\n\nlet alertMsg = {\n    payload: alertName\n};\n\n// Alarm status\nlet alarmMsg = {\n    payload: latest.alarm == 1 || latest.alarm === true\n        ? \"Alarm ON\"\n        : \"Alarm OFF\"\n};\n\n// Reason\nlet reasonMsg = {\n    payload: latest.reason ?? \"No reason\"\n};\n\n// ML inference output\nlet mlClassMsg = {\n    payload: latest.ml_class ?? \"Waiting for ML inference\"\n};\n\nlet mlConfidenceMsg = {\n    payload: latest.ml_confidence == null\n        ? \"Waiting for ML confidence\"\n        : `${latest.ml_confidence}%`\n};\n\n// Return messages to 11 outputs\nreturn [\n    temperatureMsg,      // Output 1 → Temperature Gauge\n    humidityMsg,         // Output 2 → Humidity Gauge\n    gasMsg,              // Output 3 → Gas Gauge\n    motionMsg,           // Output 4 → Motion Text\n    nightMsg,            // Output 5 → Day/Night Text\n    durationMsg,         // Output 6 → Motion Duration Gauge\n    alertMsg,            // Output 7 → Alert Class Text\n    alarmMsg,            // Output 8 → Alarm Status Text\n    reasonMsg,           // Output 9 → Reason Text\n    mlClassMsg,          // Output 10 → ML Class Text\n    mlConfidenceMsg      // Output 11 → ML Confidence Text\n];",
        "outputs": 11,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
